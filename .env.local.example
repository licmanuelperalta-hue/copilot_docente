# OpenAI API
OPENAI_API_KEY=sk-your-api-key-here

# NVIDIA NIM API
NVIDIA_API_KEY=nvapi-your-api-key-here
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1

# Alternativa: Gemini API
# GEMINI_API_KEY=your-gemini-key-here

# Database (si deseas PostgreSQL después)
# DATABASE_URL=postgresql://user:password@localhost:5432/copilot_docente

# Firebase (opcional para autenticación)
# NEXT_PUBLIC_FIREBASE_API_KEY=your-key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-domain
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
